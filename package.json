{
  "name": "dsa5-statblock-importer",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "bootstrap:e2e": "node --experimental-vm-modules scripts/bootstrap-e2e-fixtures.js",
    "lint": "eslint --no-error-on-unmatched-pattern src/ tests/",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.44.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
