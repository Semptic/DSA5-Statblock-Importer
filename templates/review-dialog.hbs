<form class="dsa5-review-form" autocomplete="off">

  <!-- Name (required) -->
  <div class="form-group {{#unless name}}required{{/unless}}">
    <label>Name *</label>
    <input type="text" name="actor-name" value="{{name}}"
      placeholder="Name eingeben..." class="{{#unless name}}error{{/unless}}">
  </div>

  {{#if npcCategory}}
  <div class="form-group">
    <label>Kategorie</label>
    <span>[{{npcCategory}}] {{titel}}</span>
  </div>
  {{/if}}

  <!-- Attributes -->
  <fieldset><legend>Attribute</legend>
    {{#each attributes}}
    <div class="attr-group">
      <label>{{@key}}</label>
      <input type="number" name="attr-{{@key}}" value="{{this}}">
    </div>
    {{/each}}
  </fieldset>

  <!-- Editable import summary -->
  <fieldset class="edit-summary"><legend>Zusammenfassung bearbeiten</legend>
    <div class="form-group">
      <label>Waffen</label>
      <textarea name="edit-weapons" rows="2">{{editWeapons}}</textarea>
    </div>
    <div class="form-group">
      <label>Rüstung</label>
      <textarea name="edit-armor" rows="1">{{editArmor}}</textarea>
    </div>
    <div class="form-group">
      <label>Sonderfertigkeiten</label>
      <textarea name="edit-sf" rows="2">{{editSf}}</textarea>
    </div>
    <div class="form-group">
      <label>Vorteile</label>
      <textarea name="edit-vorteile" rows="2">{{editVorteile}}</textarea>
    </div>
    <div class="form-group">
      <label>Nachteile</label>
      <textarea name="edit-nachteile" rows="2">{{editNachteile}}</textarea>
    </div>
    <div class="form-group">
      <label>Sprachen</label>
      <textarea name="edit-sprachen" rows="1">{{editSprachen}}</textarea>
    </div>
    <div class="form-group">
      <label>Schriften</label>
      <textarea name="edit-schriften" rows="1">{{editSchriften}}</textarea>
    </div>
  </fieldset>

  <div class="form-group reanalyse-row">
    <button type="button" name="reanalyse">
      <i class="fas fa-sync-alt"></i>
      Neu analysieren
    </button>
  </div>

  <!-- All compendium items: exact matches, approximate matches, and missing — all drag-droppable -->
  {{#if allItems.length}}
  <fieldset class="compendium-items"><legend>Kompendium-Items</legend>
    {{#each allItems}}
    <div class="compendium-row compendium-row--{{status}}">
      <span class="compendium-row__orig" title="{{type}}">{{originalName}}</span>
      <span class="compendium-row__sep">→</span>
      <div class="item-drop-zone" data-idx="{{idx}}">
        {{#if matchedName}}
        <span class="drop-zone__found">{{matchedName}}</span>
        {{else}}
        <span class="drop-zone__empty">nicht gefunden — hierher ziehen</span>
        {{/if}}
      </div>
    </div>
    {{/each}}
  </fieldset>
  {{/if}}

  <!-- Equipment packs (found, but must be dragged from chat after creation) -->
  {{#if packs.length}}
  <fieldset class="packs"><legend>Ausrüstungspakete</legend>
    {{#each packs}}
    <p>{{item.name}} — nach Erstellung aus dem Chat ziehen</p>
    {{/each}}
  </fieldset>
  {{/if}}

  <!-- Spezies / Kultur / Profession — drag from compendium -->
  <fieldset><legend>Herkunft (optional)</legend>
    <div class="compendium-row compendium-row--empty">
      <label class="compendium-row__orig">Spezies</label>
      <span class="compendium-row__sep">→</span>
      <div class="item-drop-zone" data-field="spezies">
        <span class="drop-zone__empty">Aus Kompendium ziehen…</span>
      </div>
    </div>
    <div class="compendium-row compendium-row--empty">
      <label class="compendium-row__orig">Kultur</label>
      <span class="compendium-row__sep">→</span>
      <div class="item-drop-zone" data-field="kultur">
        <span class="drop-zone__empty">Aus Kompendium ziehen…</span>
      </div>
    </div>
    <div class="compendium-row compendium-row--empty">
      <label class="compendium-row__orig">Profession</label>
      <span class="compendium-row__sep">→</span>
      <div class="item-drop-zone" data-field="profession">
        <span class="drop-zone__empty">Aus Kompendium ziehen…</span>
      </div>
    </div>
    <div class="form-group profession-text-row">
      <label>Profession (Freitext)</label>
      <input type="text" name="profession-text" placeholder="z.B. Ritter, Händler…">
    </div>
  </fieldset>

  <div class="form-footer">
    <button type="button" name="cancel">{{localize "DSA5SI.review.cancel"}}</button>
    <button type="button" name="create" class="default">
      <i class="fas fa-user-plus"></i>
      {{localize "DSA5SI.review.create"}}
    </button>
  </div>
</form>
